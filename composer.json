{
    "name": "imarc/fort",
    "description": "Safe API filtering & sorting for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.2",
        "laravel/framework": "^10.0|^11.0|^12.0|^13.0"
    },
    "require-dev": {
        "orchestra/testbench": "^8.24|^9.8|^10.0|^11.0",
        "phpunit/phpunit": "^10.5.35|^11.5.3|^12.0"
    },
    "autoload": {
        "psr-4": {
            "Imarc\\Fort\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imarc\\Fort\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
