{
    "name": "imarc/fort",
    "description": "Safe API filtering & sorting for Laravel",
    "type": "library",
    "license": "MIT",
    "require": {
        "php": "^8.4",
        "laravel/framework": "^12.0"
    },
    "require-dev": {
        "orchestra/testbench": "^10.0",
        "phpunit/phpunit": "^11.5"
    },
    "autoload": {
        "psr-4": {
            "Imarc\\Fort\\": "src/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Imarc\\Fort\\Tests\\": "tests/"
        }
    },
    "config": {
        "sort-packages": true
    },
    "minimum-stability": "stable",
    "prefer-stable": true
}
